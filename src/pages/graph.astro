---
import Layout from '../layouts/Layout.astro';
import { chapters, concepts } from '../data/chapters';

// Build graph data
interface GraphNode {
  id: string;
  label: string;
  type: 'chapter' | 'concept';
  color: string;
  size: number;
}

interface GraphEdge {
  source: string;
  target: string;
}

const nodes: GraphNode[] = [
  ...chapters
    .filter(c => c.status === 'available')
    .map(c => ({
      id: c.id,
      label: c.title,
      type: 'chapter' as const,
      color: c.color,
      size: c.pages > 15 ? 20 : c.pages > 10 ? 16 : 13,
    })),
  ...concepts.map(c => ({
    id: c.id,
    label: c.title,
    type: 'concept' as const,
    color: '#6b7280',
    size: 10,
  })),
];

const edges: GraphEdge[] = [
  ...concepts.flatMap(c =>
    c.relatedChapters.map(ch => ({ source: c.id, target: ch }))
  ),
  ...concepts.flatMap(c =>
    c.relatedConcepts.map(rc => ({ source: c.id, target: rc }))
  ),
];

const graphData = JSON.stringify({ nodes, edges });
---

<Layout title="知识图谱">
  <div class="graph-page">
    <div class="graph-header">
      <div class="container">
        <h1 class="graph-title">知识图谱</h1>
        <p class="graph-desc">
          {nodes.length} 个节点 · {edges.length} 条连线 — 探索 5hows 各章节与核心概念的关联网络
        </p>
        <div class="graph-legend">
          <div class="legend-item">
            <span class="legend-dot" style="background:#6366f1;"></span>章节（圆形大小代表篇幅）
          </div>
          <div class="legend-item">
            <span class="legend-dot" style="background:#6b7280;"></span>核心概念
          </div>
        </div>
      </div>
    </div>
    <div class="graph-container">
      <canvas id="graph-canvas"></canvas>
      <div id="tooltip" class="tooltip"></div>
    </div>
  </div>
</Layout>

<script define:vars={{ graphData }}>
  const data = JSON.parse(graphData);
  const canvas = document.getElementById('graph-canvas');
  const tooltip = document.getElementById('tooltip');
  const ctx = canvas.getContext('2d');

  let width = canvas.parentElement.offsetWidth;
  let height = canvas.parentElement.offsetHeight;
  canvas.width = width;
  canvas.height = height;

  // Node positions
  const nodeMap = {};
  const nodes = data.nodes.map(n => {
    const node = {
      ...n,
      x: Math.random() * (width - 100) + 50,
      y: Math.random() * (height - 100) + 50,
      vx: 0, vy: 0,
    };
    nodeMap[n.id] = node;
    return node;
  });

  const edges = data.edges.filter(e => nodeMap[e.source] && nodeMap[e.target]);

  // Force simulation
  let frame = 0;
  const alpha = { current: 1 };

  function tick() {
    if (alpha.current < 0.005) return;
    alpha.current *= 0.98;

    // Repulsion
    for (let i = 0; i < nodes.length; i++) {
      for (let j = i + 1; j < nodes.length; j++) {
        const a = nodes[i], b = nodes[j];
        const dx = b.x - a.x, dy = b.y - a.y;
        const dist = Math.sqrt(dx*dx + dy*dy) || 1;
        const force = (2000 / (dist * dist)) * alpha.current;
        const fx = (dx / dist) * force, fy = (dy / dist) * force;
        a.vx -= fx; a.vy -= fy;
        b.vx += fx; b.vy += fy;
      }
    }

    // Attraction along edges
    for (const e of edges) {
      const a = nodeMap[e.source], b = nodeMap[e.target];
      if (!a || !b) continue;
      const dx = b.x - a.x, dy = b.y - a.y;
      const dist = Math.sqrt(dx*dx + dy*dy) || 1;
      const target = 120;
      const force = (dist - target) * 0.04 * alpha.current;
      const fx = (dx / dist) * force, fy = (dy / dist) * force;
      a.vx += fx; a.vy += fy;
      b.vx -= fx; b.vy -= fy;
    }

    // Center gravity
    for (const n of nodes) {
      n.vx += (width/2 - n.x) * 0.005 * alpha.current;
      n.vy += (height/2 - n.y) * 0.005 * alpha.current;
    }

    // Apply velocity
    for (const n of nodes) {
      n.vx *= 0.8; n.vy *= 0.8;
      n.x += n.vx; n.y += n.vy;
      n.x = Math.max(n.size + 5, Math.min(width - n.size - 5, n.x));
      n.y = Math.max(n.size + 5, Math.min(height - n.size - 5, n.y));
    }
  }

  function draw() {
    ctx.clearRect(0, 0, width, height);

    // Edges
    ctx.globalAlpha = 0.25;
    for (const e of edges) {
      const a = nodeMap[e.source], b = nodeMap[e.target];
      if (!a || !b) continue;
      ctx.beginPath();
      ctx.strokeStyle = '#9ca3af';
      ctx.lineWidth = 1;
      ctx.moveTo(a.x, a.y);
      ctx.lineTo(b.x, b.y);
      ctx.stroke();
    }
    ctx.globalAlpha = 1;

    // Nodes
    for (const n of nodes) {
      ctx.beginPath();
      ctx.arc(n.x, n.y, n.size, 0, Math.PI * 2);
      ctx.fillStyle = n.color;
      ctx.fill();

      if (n.type === 'chapter') {
        ctx.strokeStyle = 'rgba(255,255,255,0.8)';
        ctx.lineWidth = 2;
        ctx.stroke();
      }

      // Label
      ctx.font = n.type === 'chapter'
        ? `bold ${Math.max(10, n.size - 2)}px 'Noto Sans SC', sans-serif`
        : `${Math.max(9, n.size - 3)}px 'Noto Sans SC', sans-serif`;
      ctx.fillStyle = '#374151';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'top';
      ctx.fillText(n.label.length > 6 ? n.label.slice(0, 6) + '…' : n.label, n.x, n.y + n.size + 4);
    }
  }

  function loop() {
    tick();
    draw();
    requestAnimationFrame(loop);
  }
  loop();

  // Hover tooltip
  canvas.addEventListener('mousemove', (e) => {
    const rect = canvas.getBoundingClientRect();
    const mx = e.clientX - rect.left;
    const my = e.clientY - rect.top;
    let hit = null;
    for (const n of nodes) {
      const dx = mx - n.x, dy = my - n.y;
      if (Math.sqrt(dx*dx + dy*dy) < n.size + 4) { hit = n; break; }
    }
    if (hit) {
      tooltip.style.display = 'block';
      tooltip.style.left = (e.clientX + 12) + 'px';
      tooltip.style.top = (e.clientY - 28) + 'px';
      tooltip.textContent = hit.label + (hit.type === 'chapter' ? ' (章节)' : ' (概念)');
      canvas.style.cursor = 'pointer';
    } else {
      tooltip.style.display = 'none';
      canvas.style.cursor = 'default';
    }
  });

  // Click navigate
  canvas.addEventListener('click', (e) => {
    const rect = canvas.getBoundingClientRect();
    const mx = e.clientX - rect.left;
    const my = e.clientY - rect.top;
    for (const n of nodes) {
      const dx = mx - n.x, dy = my - n.y;
      if (Math.sqrt(dx*dx + dy*dy) < n.size + 4) {
        if (n.type === 'chapter') window.location.href = `/chapters/${n.id}`;
        break;
      }
    }
  });

  // Resize
  window.addEventListener('resize', () => {
    width = canvas.parentElement.offsetWidth;
    height = canvas.parentElement.offsetHeight;
    canvas.width = width;
    canvas.height = height;
    alpha.current = 1;
  });
</script>

<style>
  .graph-page {
    display: flex;
    flex-direction: column;
    height: calc(100vh - var(--nav-height));
    overflow: hidden;
  }

  .graph-header {
    flex-shrink: 0;
    padding: 24px 0;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .graph-title {
    font-size: 24px;
    font-weight: 700;
    letter-spacing: -0.5px;
    margin-bottom: 6px;
  }

  .graph-desc {
    font-size: 14px;
    color: var(--color-text-secondary);
    margin-bottom: 12px;
  }

  .graph-legend {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: var(--color-text-secondary);
  }

  .legend-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .graph-container {
    flex: 1;
    position: relative;
    background: #fafafa;
  }

  #graph-canvas {
    width: 100%;
    height: 100%;
    display: block;
  }

  .tooltip {
    position: fixed;
    display: none;
    background: rgba(17,24,39,0.9);
    color: white;
    padding: 6px 12px;
    border-radius: 6px;
    font-size: 13px;
    pointer-events: none;
    z-index: 1000;
    white-space: nowrap;
  }
</style>

---
import Layout from '../../layouts/Layout.astro';
import { chapters } from '../../data/chapters';
import type { GetStaticPaths } from 'astro';
import { readFileSync } from 'node:fs';
import { join } from 'node:path';

export const getStaticPaths = (() => {
  return chapters
    .filter(ch => ch.status === 'available')
    .map(ch => ({ params: { slug: ch.slug }, props: { chapter: ch } }));
}) satisfies GetStaticPaths;

const { chapter } = Astro.props;

// Read from content/chapters directory (relative to project root)
const contentDir = join(process.cwd(), 'src/content/chapters');
const filePath = join(contentDir, `${chapter.id}.md`);
let rawContent = '';
try {
  rawContent = readFileSync(filePath, 'utf-8');
} catch (e) {
  rawContent = '';
}

// Parse markdown content with semantic blocks
interface ContentBlock {
  type: 'text' | 'blockquote' | 'theorem' | 'supplement' | 'corollary' | 'fact' | 'guess' | 'innovation';
  content: string;
  children?: ContentBlock[];
}

// Parse color blocks from text (strips leading > if inside blockquote)
function parseColorBlocks(text: string, insideBlockquote = false): ContentBlock[] {
  const blocks: ContentBlock[] = [];
  // Pattern: :::type\n...\n::: or >:::type\n...\n>:::
  const blockPattern = /^(?:>)?:::(theorem|supplement|corollary|fact|guess|innovation)\s*\n([\s\S]*?)(?:>)?:::/gm;
  
  const matches: Array<{type: string, content: string, start: number, end: number}> = [];
  let match;
  while ((match = blockPattern.exec(text)) !== null) {
    matches.push({
      type: match[1],
      content: match[2].trim(),
      start: match.index,
      end: match.index + match[0].length
    });
  }
  
  if (matches.length === 0) {
    const cleaned = insideBlockquote ? text.replace(/^>\s?/gm, '').trim() : text.trim();
    if (cleaned) blocks.push({ type: 'text', content: cleaned });
    return blocks;
  }
  
  let lastIndex = 0;
  for (const m of matches) {
    if (m.start > lastIndex) {
      const before = text.slice(lastIndex, m.start).trim();
      const cleaned = insideBlockquote ? before.replace(/^>\s?/gm, '').trim() : before;
      if (cleaned) blocks.push({ type: 'text', content: cleaned });
    }
    const cleanContent = m.content.replace(/^>\s?/gm, '').trim();
    blocks.push({ type: m.type as ContentBlock['type'], content: cleanContent });
    lastIndex = m.end;
  }
  
  if (lastIndex < text.length) {
    const after = text.slice(lastIndex).trim();
    const cleaned = insideBlockquote ? after.replace(/^>\s?/gm, '').trim() : after;
    if (cleaned) blocks.push({ type: 'text', content: cleaned });
  }
  
  return blocks;
}

function parseContent(text: string): ContentBlock[] {
  const blocks: ContentBlock[] = [];
  
  // First, detect blockquote groups (consecutive lines starting with >)
  // Split into: blockquote sections and non-blockquote sections
  const lines = text.split('\n');
  let i = 0;
  
  while (i < lines.length) {
    const line = lines[i];
    
    if (line.match(/^>\s?/)) {
      // Start of a blockquote (includes lines like >:::theorem)
      const bqLines: string[] = [];
      while (i < lines.length && (lines[i].match(/^>\s?/) || lines[i].match(/^:::/) || lines[i] === ':::' || lines[i] === '::')) {
        bqLines.push(lines[i]);
        i++;
      }
      const bqText = bqLines.join('\n');
      // Parse color blocks inside the blockquote
      const children = parseColorBlocks(bqText, true);
      blocks.push({ type: 'blockquote', content: bqText, children });
    } else if (line.match(/^:::/) || line === ':::' || line === '::') {
      // Color block marker — collect it and following content
      i++; // skip
    } else {
      // Regular text — collect until next blockquote or color marker
      const textLines: string[] = [];
      while (i < lines.length && !lines[i].match(/^>\s?/) && !lines[i].match(/^:::/)) {
        textLines.push(lines[i]);
        i++;
      }
      const textChunk = textLines.join('\n').trim();
      if (textChunk && !textChunk.startsWith('<!--') && textChunk !== '---') {
        // Parse color blocks within regular text too
        const colorBlocks = parseColorBlocks(textChunk, false);
        blocks.push(...colorBlocks);
      } else if (textChunk === '---') {
        blocks.push({ type: 'text', content: '---' });
      }
    }
  }
  
  return blocks;
}

// Parse pages from content (split by <!-- Page X -->)
interface Page {
  num: string;
  content: string;
  blocks: ContentBlock[];
}

const pages: Page[] = [];
if (rawContent) {
  // Remove frontmatter
  const withoutFrontmatter = rawContent.replace(/^---[\s\S]*?---\n/, '');
  // Split by page comments
  const pageSections = withoutFrontmatter.split(/<!-- Page (\d+) -->/).filter(s => s.trim());
  
  if (pageSections.length > 1 && /<!-- Page \d+ -->/.test(withoutFrontmatter)) {
    // Has explicit page markers — use them
    for (let i = 0; i < pageSections.length; i += 2) {
      const pageNum = pageSections[i] || `${Math.floor(i/2) + 1}`;
      const pageContent = pageSections[i + 1] || '';
      if (pageContent.trim()) {
        const blocks = parseContent(pageContent);
        pages.push({
          num: pageNum.padStart(2, '0'),
          content: pageContent.trim(),
          blocks
        });
      }
    }
  } else {
    // No page markers — treat entire content as one page
    const blocks = parseContent(withoutFrontmatter);
    if (blocks.length > 0) {
      pages.push({
        num: '01',
        content: withoutFrontmatter.trim(),
        blocks
      });
    }
  }
}

// Find prev/next
const available = chapters.filter(c => c.status === 'available');
const idx = available.findIndex(c => c.id === chapter.id);
const prev = idx > 0 ? available[idx - 1] : null;
const next = idx < available.length - 1 ? available[idx + 1] : null;

// Semantic type labels
const typeLabels: Record<string, string> = {
  theorem: '公理 / 定理',
  supplement: '解释 / 补充',
  corollary: '推论 / 核心推论',
  fact: '事实 / 数据',
  guess: '猜想 / 评论',
  innovation: '理论创新'
};

// Inline markdown renderer (server-side)
function renderInline(text: string): string {
  // Strip leading > blockquote markers (already handled by block parser)
  const cleaned = text.replace(/^>\s?/gm, '');
  return cleaned
    .replace(/==(.+?)==/g, '<mark class="highlight-mark">$1</mark>')
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.+?)\*/g, '<em>$1</em>')
    .replace(/^### (.+)$/gm, '<h3>$1</h3>')
    .replace(/^## (.+)$/gm, '<h2>$1</h2>')
    .replace(/^# (.+)$/gm, '<h1>$1</h1>')
    .replace(/^---$/gm, '<hr/>')
    .replace(/^\*(.+)\*$/gm, '<p><em>$1</em></p>');
}
---

<Layout title={chapter.title}>
  <div class="chapter-page">
    <!-- Chapter header -->
    <div class="chapter-header" style={`--ch-color: ${chapter.color};`}>
      <div class="container">
        <div class="chapter-header__breadcrumb">
          <a href="/">首页</a>
          <span>/</span>
          <a href="/chapters">全部章节</a>
          <span>/</span>
          <span>{chapter.title}</span>
        </div>
        <div class="chapter-header__body">
          <div class="chapter-header__num">{chapter.number ?? '·'}</div>
          <div class="chapter-header__info">
            <h1 class="chapter-header__title">{chapter.title}</h1>
            <p class="chapter-header__subtitle">{chapter.subtitle}</p>
            <p class="chapter-header__desc">{chapter.description}</p>
            <div class="chapter-header__meta">
              <span class="meta-badge">{chapter.publishDate}</span>
              <span class="meta-badge">{pages.length} 页</span>
              <span class="meta-badge">{chapter.type === 'extra' ? '番外篇' : chapter.type === 'intro' ? '开笔篇' : '主系列'}</span>
            </div>
          </div>
        </div>
        <div class="chapter-header__tags">
          {chapter.tags.map(t => (
            <span class="tag">{t}</span>
          ))}
        </div>
      </div>
    </div>

    <!-- Color legend -->
    <div class="color-legend">
      <div class="container">
        <div class="color-legend__inner">
          <span class="color-legend__label">配色说明</span>
          <div class="color-legend__items">
            <span class="legend-item legend-item--theorem">公理/定理</span>
            <span class="legend-item legend-item--supplement">解释/补充</span>
            <span class="legend-item legend-item--corollary">推论/结论</span>
            <span class="legend-item legend-item--fact">事实/数据</span>
            <span class="legend-item legend-item--guess">猜想/评论</span>
            <span class="legend-item legend-item--innovation">理论创新</span>
          </div>
        </div>
      </div>
    </div>

    <div class="chapter-layout">
      <!-- TOC sidebar -->
      <aside class="chapter-toc">
        <div class="toc-inner">
          <div class="toc-title">目录</div>
          <ul class="toc-list">
            {pages.map((p, i) => (
              <li>
                <a href={`#page-${p.num}`} class="toc-item">
                  第 {p.num} 页
                </a>
              </li>
            ))}
          </ul>
        </div>
      </aside>

      <!-- Content -->
      <main class="chapter-content">
        {pages.length > 0 ? (
          pages.map((page) => (
            <div id={`page-${page.num}`} class="page-block">
              <div class="page-block__header">
                <span class="page-num">第 {page.num} 页</span>
              </div>
              <div class="page-block__body">
                {page.blocks.map(block => {
                    if (block.type === 'text') {
                    // Render text: handle headings and paragraphs
                    const lines = block.content.split('\n');
                    return lines.map(line => {
                      const trimmed = line.trim();
                      if (!trimmed) return null;
                      // Markdown heading
                      if (/^#{1,4}\s/.test(trimmed)) {
                        const level = trimmed.match(/^(#{1,4})\s/)[1].length;
                        const headingText = trimmed.replace(/^#{1,4}\s/, '');
                        const Tag = `h${level}` as 'h1' | 'h2' | 'h3' | 'h4';
                        return <Tag class={level <= 2 ? 'content-heading' : 'content-subheading'} set:html={renderInline(headingText)} />;
                      }
                      // Horizontal rule
                      if (trimmed === '---') {
                        return <hr class="content-hr" />;
                      }
                      // Section numbering (e.g. "6.1 怎样生涯三连")
                      if (/^\d+\.\d+[a-z]?\.\d+/.test(trimmed)) {
                        return <h4 class="content-subheading" set:html={renderInline(trimmed)} />;
                      }
                      if (/^\d+\.\d+[a-z]?/.test(trimmed) && !/^\d+\.\d+[a-z]?\.\d/.test(trimmed)) {
                        return <h3 class="content-heading" set:html={renderInline(trimmed)} />;
                      }
                      // Regular paragraph (preserve original numbering like a. b. c.)
                      // Q&A lines
                      if (/^[QA]:\s/i.test(trimmed)) {
                        return <p class="content-paragraph" style="font-weight:600;" set:html={renderInline(trimmed)} />;
                      }
                      return <p class="content-paragraph" set:html={renderInline(trimmed)} />;
                    });
                  } else if (block.type === 'blockquote') {
                    // Render blockquote with possible colored children inside
                    // Headings (###) should be rendered OUTSIDE the blockquote
                    const children = block.children || [];
                    return (
                      <>
                        {children.map(child => {
                          if (child.type === 'text') {
                            const lines = child.content.split('\n').filter(l => l.trim());
                            const headings: string[] = [];
                            const normalLines: string[] = [];
                            for (const line of lines) {
                              const trimmed = line.trim();
                              if (/^#{1,3}\s/.test(trimmed)) {
                                headings.push(trimmed);
                              } else {
                                normalLines.push(trimmed);
                              }
                            }
                            return (
                              <>
                                {headings.map(h => <Fragment set:html={renderInline(h)} />)}
                                {normalLines.length > 0 && (
                                  <blockquote class="content-blockquote">
                                    {normalLines.map(line => (
                                      <p set:html={renderInline(line)} />
                                    ))}
                                  </blockquote>
                                )}
                              </>
                            );
                          } else {
                            const paras = child.content.split('\n').filter(l => l.trim());
                            return (
                              <blockquote class="content-blockquote">
                                {paras.map(line => (
                                  <p class={`content-color--${child.type}`} set:html={renderInline(line.trim())} />
                                ))}
                              </blockquote>
                            );
                          }
                        })}
                      </>
                    );
                  } else {
                    // Semantic color block — render inline with color, no card wrapper
                    const paras = block.content.split('\n').filter(l => l.trim());
                    return paras.map(line => {
                      const trimmed = line.trim();
                      if (!trimmed) return null;
                      return <p class={`content-paragraph content-color--${block.type}`} set:html={renderInline(trimmed)} />;
                    });
                  }
                })}
              </div>
            </div>
          ))
        ) : (
          <div class="empty-state">
            <p>内容加载中，或文件暂不可用。</p>
          </div>
        )}

        <!-- Nav -->
        <nav class="chapter-nav">
          {prev ? (
            <a href={`/chapters/${prev.slug}`} class="chapter-nav__item chapter-nav__item--prev">
              <span class="chapter-nav__label">← 上一篇</span>
              <span class="chapter-nav__title">{prev.title}</span>
            </a>
          ) : <div />}
          {next ? (
            <a href={`/chapters/${next.slug}`} class="chapter-nav__item chapter-nav__item--next">
              <span class="chapter-nav__label">下一篇 →</span>
              <span class="chapter-nav__title">{next.title}</span>
            </a>
          ) : <div />}
        </nav>
      </main>
    </div>
  </div>
</Layout>

<style>
  .chapter-header {
    padding: 48px 0;
    border-bottom: 1px solid var(--color-border);
    background: linear-gradient(to bottom, rgba(255,255,255,0) 0%, var(--color-border-subtle) 100%);
    position: relative;
  }

  .chapter-header::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 4px;
    background: var(--ch-color);
  }

  .chapter-header__breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--color-text-muted);
    margin-bottom: 32px;
  }

  .chapter-header__breadcrumb a {
    color: var(--color-text-secondary);
    text-decoration: none;
  }

  .chapter-header__breadcrumb a:hover {
    text-decoration: underline;
  }

  .chapter-header__body {
    display: flex;
    align-items: flex-start;
    gap: 24px;
    margin-bottom: 20px;
  }

  .chapter-header__num {
    flex-shrink: 0;
    width: 64px;
    height: 64px;
    border-radius: 14px;
    background: var(--ch-color);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28px;
    font-weight: 700;
    letter-spacing: -2px;
  }

  .chapter-header__title {
    font-size: 32px;
    font-weight: 700;
    letter-spacing: -0.8px;
    margin-bottom: 6px;
  }

  .chapter-header__subtitle {
    font-size: 14px;
    color: var(--color-text-muted);
    font-style: italic;
    margin-bottom: 12px;
  }

  .chapter-header__desc {
    font-size: 16px;
    color: var(--color-text-secondary);
    line-height: 1.7;
    max-width: 640px;
    margin-bottom: 16px;
  }

  .chapter-header__meta {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .meta-badge {
    display: inline-block;
    padding: 3px 10px;
    border-radius: 100px;
    font-size: 12px;
    font-weight: 500;
    background: var(--color-surface);
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
  }

  .chapter-header__tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-top: 4px;
  }

  .tag {
    padding: 3px 10px;
    border-radius: 100px;
    font-size: 12px;
    color: var(--color-text-muted);
    background: rgba(0,0,0,0.04);
    border: 1px solid var(--color-border);
  }

  /* Color legend */
  .color-legend {
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    padding: 12px 0;
  }

  .color-legend__inner {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .color-legend__label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  .color-legend__items {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .legend-item {
    font-size: 12px;
    padding: 2px 10px;
    border-radius: 100px;
    font-weight: 500;
  }

  .legend-item--theorem {
    background: rgba(231, 76, 60, 0.1);
    color: #c0392b;
    border: 1px solid rgba(231, 76, 60, 0.2);
  }

  /* Supplement - blue italic */
  .legend-item--supplement {
    background: rgba(52, 152, 219, 0.1);
    color: #2980b9;
    border: 1px solid rgba(52, 152, 219, 0.2);
  }

  .legend-item--corollary {
    background: rgba(230, 126, 34, 0.1);
    color: #d35400;
    border: 1px solid rgba(230, 126, 34, 0.2);
  }

  .legend-item--fact {
    background: rgba(39, 174, 96, 0.1);
    color: #1e8449;
    border: 1px solid rgba(39, 174, 96, 0.2);
  }

  .legend-item--guess {
    background: rgba(155, 89, 182, 0.1);
    color: #7d3c98;
    border: 1px solid rgba(155, 89, 182, 0.2);
  }

  .legend-item--innovation {
    background: rgba(149, 165, 166, 0.2);
    color: #5d6d7e;
    border: 1px solid rgba(149, 165, 166, 0.3);
    font-weight: 600;
  }

  /* Layout */
  .chapter-layout {
    display: grid;
    grid-template-columns: 220px 1fr;
    max-width: 1200px;
    margin: 0 auto;
    gap: 0;
    min-height: 100vh;
  }

  /* TOC */
  .chapter-toc {
    border-right: 1px solid var(--color-border);
    position: sticky;
    top: var(--nav-height);
    height: calc(100vh - var(--nav-height));
    overflow-y: auto;
  }

  .toc-inner {
    padding: 28px 16px;
  }

  .toc-title {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 12px;
    padding: 0 8px;
  }

  .toc-list {
    list-style: none;
    margin-bottom: 24px;
  }

  .toc-item {
    display: block;
    padding: 5px 8px;
    border-radius: var(--radius-sm);
    font-size: 13px;
    color: var(--color-text-secondary);
    transition: all 0.15s;
    text-decoration: none;
  }

  .toc-item:hover {
    color: var(--color-text);
    background: var(--color-border-subtle);
  }

  /* Content */
  .chapter-content {
    padding: 40px 56px 80px;
    max-width: 800px;
  }

  .page-block {
    margin-bottom: 48px;
    padding-bottom: 48px;
    border-bottom: 1px solid var(--color-border-subtle);
    scroll-margin-top: calc(var(--nav-height) + 20px);
  }

  .page-block:last-of-type {
    border-bottom: none;
  }

  .page-block__header {
    margin-bottom: 16px;
  }

  .page-num {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    padding: 2px 8px;
    border-radius: 100px;
    background: var(--color-border-subtle);
    border: 1px solid var(--color-border);
  }

  .page-block__body {
    font-size: 16px;
    line-height: 1.9;
  }

  /* Content typography */
  .content-paragraph {
    margin-bottom: 0.8em;
    color: #374151;
  }

  .content-heading {
    font-size: 17px;
    font-weight: 700;
    color: #1a1a1a;
    margin: 1.5em 0 0.5em;
    letter-spacing: -0.2px;
  }

  .content-subheading {
    font-size: 15px;
    font-weight: 600;
    color: #2d2d2d;
    margin: 1.2em 0 0.4em;
  }

  .content-list-item {
    margin-bottom: 0.4em;
    color: #374151;
    padding-left: 0.5em;
  }

  .content-blockquote {
    margin: 1em 0;
    padding: 0.6em 1em;
    border-left: 3px solid var(--color-border);
    color: var(--color-text-secondary);
    background: var(--color-surface);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    font-size: 15px;
  }

  .content-hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2em 0;
  }

  /* Inline color styles (no card wrapper) */
  .content-color--theorem {
    color: #c0392b;
    font-weight: 600;
  }

  .content-color--supplement {
    color: #2980b9;
    font-style: italic;
  }

  .content-color--corollary {
    color: #d35400;
    font-weight: 600;
  }

  .content-color--fact {
    color: #1e8449;
  }

  .content-color--guess {
    color: #7d3c98;
    font-style: italic;
  }

  .content-color--innovation {
    color: #5d6d7e;
    background: linear-gradient(to top, rgba(149, 165, 166, 0.2) 40%, transparent 40%);
    font-weight: 500;
  }

  /* Obsidian ==highlight== syntax */
  .highlight-mark {
    background: rgba(149, 165, 166, 0.25);
    color: inherit;
    padding: 1px 3px;
    border-radius: 2px;
  }

  /* Chapter nav */
  .chapter-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-top: 40px;
    padding-top: 32px;
    border-top: 1px solid var(--color-border);
  }

  .chapter-nav__item {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 16px 20px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition: all 0.15s;
  }

  .chapter-nav__item:hover {
    border-color: #9ca3af;
    background: var(--color-border-subtle);
  }

  .chapter-nav__item--next {
    text-align: right;
  }

  .chapter-nav__label {
    font-size: 12px;
    color: var(--color-text-muted);
  }

  .chapter-nav__title {
    font-size: 15px;
    font-weight: 600;
  }

  .empty-state {
    padding: 60px 0;

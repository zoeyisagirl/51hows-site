---
import Layout from '../../../layouts/Layout.astro';
import { articles } from '../../../data/articles';
import { getDictionary, type Locale } from '../../../i18n';
import { readFileSync, existsSync } from 'node:fs';
import { join } from 'node:path';

export function getStaticPaths() {
  const paths: { params: { locale: string; slug: string }; props: { article: (typeof articles)[0]; locale: Locale } }[] = [];
  for (const a of articles) {
    paths.push({ params: { locale: 'zh', slug: a.slug }, props: { article: a, locale: 'zh' as Locale } });
    paths.push({ params: { locale: 'en', slug: a.slug }, props: { article: a, locale: 'en' as Locale } });
  }
  return paths;
}

const { article, locale } = Astro.props;
// Articles are Chinese-only, always use zh dictionary
const t = getDictionary('zh');

// Read markdown content (Chinese only, no English version)
const contentDir = join(process.cwd(), 'src/content/articles');
const filePath = join(contentDir, `${article.id}.md`);
let rawContent = '';
try {
  rawContent = readFileSync(filePath, 'utf-8');
} catch (e) {
  rawContent = '';
}

// Strip frontmatter
const contentWithoutFrontmatter = rawContent.replace(/^---[\s\S]*?---\n/, '');

// Parse headings for TOC
interface TocEntry {
  id: string;
  title: string;
  level: number;
}

const tocEntries: TocEntry[] = [];
const headingPattern = /^(#{1,4})\s+(.+)$/gm;
let hMatch;
while ((hMatch = headingPattern.exec(contentWithoutFrontmatter)) !== null) {
  const level = hMatch[1].length;
  const rawTitle = hMatch[2].trim();
  const title = rawTitle.replace(/\*+/g, '').replace(/<[^>]+>/g, '').trim();
  // Skip the first H1 (article title) and category subtitle
  if (title.startsWith('【') || level === 1) continue;
  const id = title
    .replace(/[^\w\u4e00-\u9fff]/g, '-')
    .replace(/-+/g, '-')
    .replace(/^-|-$/g, '')
    .toLowerCase()
    .slice(0, 60);
  if (title) {
    tocEntries.push({ id, title, level });
  }
}

// Split into paragraphs and render
function renderInline(text: string): string {
  return text
    .replace(/==(.+?)==/g, '<mark class="highlight-mark">$1</mark>')
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.+?)\*/g, '<em>$1</em>')
    .replace(/^### (.+)$/gm, '<h3>$1</h3>')
    .replace(/^## (.+)$/gm, '<h2>$1</h2>')
    .replace(/^# (.+)$/gm, '<h1>$1</h1>')
    .replace(/^---$/gm, '<hr/>');
}

// Parse content into blocks
interface ContentBlock {
  type: 'heading' | 'blockquote' | 'paragraph' | 'hr';
  content: string;
  level?: number;
  id?: string;
}

const blocks: ContentBlock[] = [];
const lines = contentWithoutFrontmatter.split('\n');
let tocIdx = 0;

for (const line of lines) {
  const trimmed = line.trim();
  if (!trimmed) continue;

  // Headings
  if (/^#{1,4}\s/.test(trimmed)) {
    const level = trimmed.match(/^(#{1,4})\s/)[1].length;
    const title = trimmed.replace(/^#{1,4}\s/, '').replace(/\*+/g, '').replace(/<[^>]+>/g, '').trim();
    // Skip article title and category subtitle
    if (title.startsWith('【') || level === 1) continue;
    const id = tocEntries[tocIdx]?.id;
    if (tocIdx < tocEntries.length) tocIdx++;
    blocks.push({ type: 'heading', content: trimmed.replace(/^#{1,4}\s/, ''), level, id });
    continue;
  }

  // Blockquotes
  if (trimmed.startsWith('>')) {
    const quoteText = trimmed.replace(/^>\s?/, '');
    blocks.push({ type: 'blockquote', content: quoteText });
    continue;
  }

  // Horizontal rule
  if (trimmed === '---') {
    blocks.push({ type: 'hr', content: '' });
    continue;
  }

  // Regular paragraph
  blocks.push({ type: 'paragraph', content: trimmed });
}

// Navigation: prev/next article
const idx = articles.findIndex(a => a.id === article.id);
const prev = idx > 0 ? articles[idx - 1] : null;
const next = idx < articles.length - 1 ? articles[idx + 1] : null;
---

<Layout title={article.title} locale={locale} t={t} disableLangSwitch={true}>
  <div class="article-page">
    <!-- Article header -->
    <div class="article-header" style={`--art-color: ${article.color};`}>
      <div class="container">
        <div class="article-header__breadcrumb">
          <a href={`/${locale}`}>{t.articleDetail.breadcrumbHome}</a>
          <span>/</span>
          <a href={`/${locale}/articles`}>{t.articleDetail.breadcrumbArticles}</a>
          <span>/</span>
          <span>{article.title}</span>
        </div>
        <div class="article-header__body">
          <div class="article-header__num">{article.number}</div>
          <div class="article-header__info">
            <div class="article-header__title-row">
              <h1 class="article-header__title">{article.title}</h1>
              <div class="article-audio-player" id="audio-player-wrap" style="display:none">
                <audio id="article-audio" src={`/audio/${article.id}-zh.mp3`} preload="none"></audio>
                <button id="audio-toggle-btn" class="audio-toggle-btn" aria-label="Listen">
                  <span class="audio-toggle-label">🎧 听全文</span>
                </button>
                <div class="audio-controls" id="audio-controls" style="display:none">
                  <button id="audio-play-btn" class="audio-play-btn" aria-label="Play/Pause">
                    <span class="audio-icon audio-icon--play">▶</span>
                    <span class="audio-icon audio-icon--pause" style="display:none">⏸</span>
                  </button>
                  <div class="audio-progress-wrap">
                    <div class="audio-progress-bar">
                      <div class="audio-progress-fill" id="audio-progress-fill"></div>
                    </div>
                    <span class="audio-time" id="audio-time">0:00 / --:--</span>
                  </div>
                  <button id="audio-speed-btn" class="audio-speed-btn" title="Speed">1×</button>
                </div>
              </div>
            </div>
            <p class="article-header__subtitle">{article.subtitle}</p>
            <p class="article-header__desc">{article.description}</p>
            <div class="article-header__meta">
              <span class="meta-badge">{article.publishDate}</span>
              <span class="meta-badge">{article.author}</span>
              <span class="meta-badge">{article.source}</span>
            </div>
          </div>
        </div>
        <div class="article-header__tags">
          {article.tags.map(tag => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      </div>
    </div>

    <div class="article-layout">
      <!-- TOC sidebar -->
      <aside class="article-toc">
        <div class="toc-inner">
          <div class="toc-title">{t.articleDetail.tocTitle}</div>
          <ul class="toc-list">
            {tocEntries.filter(e => e.level <= 3).map(entry => (
              <li class={`toc-entry ${entry.level === 3 ? 'toc-entry--sub' : ''}`}>
                <a href={`#${entry.id}`} class="toc-item" title={entry.title}>
                  {entry.title}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </aside>

      <!-- Content -->
      <main class="article-content">
        {blocks.map(block => {
          if (block.type === 'heading') {
            const Tag = `h${block.level}` as 'h1' | 'h2' | 'h3' | 'h4';
            return <Tag id={block.id} class={block.level <= 2 ? 'content-heading' : 'content-subheading'} set:html={renderInline(block.content)} />;
          }
          if (block.type === 'blockquote') {
            return <blockquote class="content-blockquote" set:html={renderInline(block.content)} />;
          }
          if (block.type === 'hr') {
            return <hr class="content-hr" />;
          }
          return <p class="content-paragraph" set:html={renderInline(block.content)} />;
        })}

        <!-- Nav -->
        <nav class="article-nav">
          {prev ? (
            <a href={`/${locale}/articles/${prev.slug}`} class="article-nav__item article-nav__item--prev">
              <span class="article-nav__label">{t.articleDetail.prevArticle}</span>
              <span class="article-nav__title">{prev.title}</span>
            </a>
          ) : <div />}
          {next ? (
            <a href={`/${locale}/articles/${next.slug}`} class="article-nav__item article-nav__item--next">
              <span class="article-nav__label">{t.articleDetail.nextArticle}</span>
              <span class="article-nav__title">{next.title}</span>
            </a>
          ) : <div />}
        </nav>
      </main>
    </div>
  </div>
</Layout>

<style>
  .article-header {
    padding: 48px 0;
    border-bottom: 1px solid var(--color-border);
    background: linear-gradient(to bottom, rgba(255,255,255,0) 0%, var(--color-border-subtle) 100%);
    position: relative;
  }

  .article-header::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 4px;
    background: var(--art-color);
  }

  .article-header__breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--color-text-muted);
    margin-bottom: 32px;
  }

  .article-header__breadcrumb a {
    color: var(--color-text-secondary);
    text-decoration: none;
  }

  .article-header__breadcrumb a:hover {
    text-decoration: underline;
  }

  .article-header__body {
    display: flex;
    align-items: flex-start;
    gap: 24px;
    margin-bottom: 20px;
  }

  .article-header__num {
    flex-shrink: 0;
    width: 64px;
    height: 64px;
    border-radius: 14px;
    background: var(--art-color);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28px;
    font-weight: 700;
    letter-spacing: -2px;
  }

  .article-header__title {
    font-size: 32px;
    font-weight: 700;
    letter-spacing: -0.8px;
    margin-bottom: 0;
    line-height: 1.3;
  }

  .article-header__title-row {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 6px;
  }

  .article-header__title-row .article-header__title {
    margin-bottom: 0;
  }

  /* Audio Player */
  .article-audio-player {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 4px 12px 4px 4px;
    background: rgba(255,255,255,0.9);
    border-radius: 8px;
    border: 1px solid rgba(0,0,0,0.12);
    vertical-align: middle;
    transition: all 0.25s ease;
  }
  .audio-toggle-btn {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 3px 8px;
    background: transparent;
    border: none;
    cursor: pointer;
    border-radius: 6px;
    transition: background 0.15s;
  }
  .audio-toggle-btn:hover {
    background: rgba(0,0,0,0.06);
  }
  .audio-toggle-label {
    font-size: 13px;
    color: var(--art-color, #333);
    font-weight: 600;
    white-space: nowrap;
  }
  .audio-controls {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .audio-play-btn {
    flex-shrink: 0;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: var(--art-color, #333);
    color: #fff;
    border: none;
    cursor: pointer;
    font-size: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.15s, background 0.15s;
  }
  .audio-play-btn:hover {
    transform: scale(1.1);
  }
  .audio-progress-wrap {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .audio-progress-bar {
    width: 140px;
    height: 4px;
    background: rgba(0,0,0,0.12);
    border-radius: 2px;
    cursor: pointer;
    overflow: hidden;
  }
  .audio-progress-fill {
    height: 100%;
    width: 0%;
    background: var(--art-color, #333);
    border-radius: 2px;
    transition: width 0.5s linear;
  }
  .audio-time {
    font-size: 11px;
    color: rgba(0,0,0,0.55);
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }
  .audio-speed-btn {
    flex-shrink: 0;
    padding: 2px 6px;
    border-radius: 6px;
    background: rgba(0,0,0,0.06);
    color: var(--art-color, #333);
    border: 1px solid rgba(0,0,0,0.1);
    font-size: 11px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s;
  }
  .audio-speed-btn:hover {
    background: rgba(0,0,0,0.12);
  }

  /* Audio reading highlight */
  .audio-reading {
    background: rgba(255, 230, 100, 0.55) !important;
    border-radius: 4px;
    transition: background 0.4s ease;
  }

  .article-header__subtitle {
    font-size: 14px;
    color: var(--color-text-muted);
    font-style: italic;
    margin-bottom: 12px;
  }

  .article-header__desc {
    font-size: 16px;
    color: var(--color-text-secondary);
    line-height: 1.7;
    max-width: 640px;
    margin-bottom: 16px;
  }

  .article-header__meta {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .meta-badge {
    display: inline-block;
    padding: 3px 10px;
    border-radius: 100px;
    font-size: 12px;
    font-weight: 500;
    background: var(--color-surface);
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
  }

  .article-header__tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-top: 4px;
  }

  .tag {
    padding: 3px 10px;
    border-radius: 100px;
    font-size: 12px;
    color: var(--color-text-muted);
    background: rgba(0,0,0,0.04);
    border: 1px solid var(--color-border);
  }

  /* Layout */
  .article-layout {
    display: grid;
    grid-template-columns: 220px 1fr;
    max-width: 1200px;
    margin: 0 auto;
    gap: 0;
    min-height: 100vh;
  }

  /* TOC */
  .article-toc {
    border-right: 1px solid var(--color-border);
    position: sticky;
    top: var(--nav-height);
    height: calc(100vh - var(--nav-height));
    overflow-y: auto;
  }

  .toc-inner {
    padding: 28px 16px;
  }

  .toc-title {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 12px;
    padding: 0 8px;
  }

  .toc-list {
    list-style: none;
    margin-bottom: 24px;
  }

  .toc-item {
    display: block;
    padding: 5px 8px;
    border-radius: var(--radius-sm);
    font-size: 13px;
    color: var(--color-text-secondary);
    transition: all 0.15s;
    text-decoration: none;
  }

  .toc-item:hover {
    color: var(--color-text);
    background: var(--color-border-subtle);
  }

  .toc-entry--sub .toc-item {
    padding-left: 16px;
    font-size: 12px;
    font-weight: 400;
    color: var(--color-text-muted);
  }

  /* Content */
  .article-content {
    padding: 40px 56px 80px;
    max-width: 800px;
  }

  .content-heading {
    font-size: 20px;
    font-weight: 700;
    color: #1a1a1a;
    margin: 1.8em 0 0.6em;
    letter-spacing: -0.3px;
    scroll-margin-top: calc(var(--nav-height) + 20px);
  }

  .content-subheading {
    font-size: 17px;
    font-weight: 600;
    color: #2d2d2d;
    margin: 1.4em 0 0.5em;
    scroll-margin-top: calc(var(--nav-height) + 20px);
  }

  .content-paragraph {
    margin-bottom: 0.8em;
    color: #374151;
    font-size: 16px;
    line-height: 1.9;
  }

  .content-blockquote {
    margin: 1.2em 0;
    padding: 0.6em 1.2em;
    border-left: 3px solid var(--color-border);
    color: var(--color-text-secondary);
    background: var(--color-surface);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    font-size: 15px;
    line-height: 1.8;
  }

  .content-hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2em 0;
  }

  .highlight-mark {
    background: rgba(149, 165, 166, 0.25);
    color: inherit;
    padding: 1px 3px;
    border-radius: 2px;
  }

  /* Article nav */
  .article-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-top: 40px;
    padding-top: 32px;
    border-top: 1px solid var(--color-border);
  }

  .article-nav__item {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 16px 20px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition: all 0.15s;
  }

  .article-nav__item:hover {
    border-color: #9ca3af;
    background: var(--color-border-subtle);
  }

  .article-nav__item--next {
    text-align: right;
  }

  .article-nav__label {
    font-size: 12px;
    color: var(--color-text-muted);
  }

  .article-nav__title {
    font-size: 15px;
    font-weight: 600;
  }

  @media (max-width: 1024px) {
    .article-layout {
      grid-template-columns: 1fr;
    }
    .article-toc {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .article-content {
      padding: 24px 20px 60px;
    }
    .article-header__body {
      flex-direction: column;
    }
    .article-nav {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const audio = document.getElementById('article-audio') as HTMLAudioElement | null;
  const playBtn = document.getElementById('audio-play-btn');
  const progressFill = document.getElementById('audio-progress-fill');
  const timeEl = document.getElementById('audio-time');
  const speedBtn = document.getElementById('audio-speed-btn');

  if (audio && playBtn) {
    const iconPlay = playBtn.querySelector('.audio-icon--play') as HTMLElement;
    const iconPause = playBtn.querySelector('.audio-icon--pause') as HTMLElement;
    const speeds = [1, 1.25, 1.5, 1.75, 2];
    let speedIdx = 0;

    function formatTime(s: number) {
      const m = Math.floor(s / 60);
      const sec = Math.floor(s % 60).toString().padStart(2, '0');
      return `${m}:${sec}`;
    }

    // ── Reading highlight (VTT-driven) ────────────────────────────────────
    type VttCue = { start: number; end: number; text: string };
    type SegInfo = { el: Element; start: number; end: number };
    let vttCues: VttCue[] = [];
    let segments: SegInfo[] = [];
    let lastHighlighted: Element | null = null;
    let vttLoaded = false;

    function parseVttTs(ts: string): number {
      const parts = ts.trim().split(':');
      if (parts.length === 3) {
        return parseInt(parts[0]) * 3600 + parseInt(parts[1]) * 60 + parseFloat(parts[2]);
      }
      return parseInt(parts[0]) * 60 + parseFloat(parts[1]);
    }

    function parseVtt(text: string): VttCue[] {
      const cues: VttCue[] = [];
      const blocks = text.split(/\n\n+/);
      for (const block of blocks) {
        const lines = block.trim().split('\n');
        const tsLine = lines.find(l => l.includes('-->'));
        if (!tsLine) continue;
        const [startStr, endStr] = tsLine.split('-->').map(s => s.trim());
        const cueText = lines.slice(lines.indexOf(tsLine) + 1).join(' ').trim();
        if (cueText) {
          cues.push({ start: parseVttTs(startStr), end: parseVttTs(endStr), text: cueText });
        }
      }
      return cues;
    }

    function normalize(s: string): string {
      return s.replace(/[\s\u3000\u00a0，。！？、,.!?:：；;""''「」【】\-—]/g, '').toLowerCase();
    }

    function buildSegments() {
      const container = document.querySelector('.article-content');
      if (!container || vttCues.length === 0) return;

      const nodes = Array.from(
        container.querySelectorAll('h2, h3, h4, p')
      ).filter(el => (el.textContent || '').trim().length > 3);

      if (nodes.length === 0) return;

      const nodeNorms = nodes.map(el => normalize((el.textContent || '').trim()));
      const nodeCueMap = new Map<Element, number[]>();
      let nodeIdx = 0;

      for (let ci = 0; ci < vttCues.length; ci++) {
        const cueNorm = normalize(vttCues[ci].text);
        if (cueNorm.length < 3) continue;

        const searchEnd = Math.min(nodes.length, nodeIdx + 6);
        let matchedNode = -1;

        for (let ni = nodeIdx; ni < searchEnd; ni++) {
          const nn = nodeNorms[ni];
          if (nn.includes(cueNorm)) { matchedNode = ni; break; }
          if (cueNorm.includes(nn) && nn.length >= 4) { matchedNode = ni; break; }
          const prefixLen = Math.min(8, cueNorm.length);
          if (prefixLen >= 4 && nn.includes(cueNorm.slice(0, prefixLen))) { matchedNode = ni; break; }
        }

        if (matchedNode >= 0) {
          nodeIdx = matchedNode;
          const el = nodes[matchedNode];
          if (!nodeCueMap.has(el)) nodeCueMap.set(el, []);
          nodeCueMap.get(el)!.push(ci);
        }
      }

      segments = [];
      for (const el of nodes) {
        const cueIndices = nodeCueMap.get(el);
        if (!cueIndices || cueIndices.length === 0) continue;
        segments.push({
          el,
          start: vttCues[cueIndices[0]].start,
          end: vttCues[cueIndices[cueIndices.length - 1]].end,
        });
      }

      for (let i = 0; i < segments.length - 1; i++) {
        if (segments[i].end > segments[i + 1].start) {
          segments[i].end = segments[i + 1].start;
        }
      }
    }

    function highlightAt(t: number) {
      let lo = 0, hi = segments.length - 1, found = -1;
      while (lo <= hi) {
        const mid = (lo + hi) >> 1;
        if (segments[mid].end < t) { lo = mid + 1; }
        else if (segments[mid].start > t) { hi = mid - 1; }
        else { found = mid; break; }
      }
      const target = found >= 0 ? segments[found].el : null;
      if (target === lastHighlighted) return;
      if (lastHighlighted) lastHighlighted.classList.remove('audio-reading');
      if (target) {
        target.classList.add('audio-reading');
        const rect = target.getBoundingClientRect();
        if (rect.top < 80 || rect.bottom > window.innerHeight - 40) {
          target.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
      }
      lastHighlighted = target;
    }

    function clearHighlight() {
      if (lastHighlighted) lastHighlighted.classList.remove('audio-reading');
      lastHighlighted = null;
    }

    async function loadVttAndBuild(vttUrl: string) {
      if (vttLoaded) return;
      vttLoaded = true;
      try {
        const res = await fetch(vttUrl);
        if (!res.ok) return;
        const text = await res.text();
        vttCues = parseVtt(text);
        buildSegments();
      } catch (e) {
        console.warn('VTT load failed, highlight disabled', e);
      }
    }

    // Probe audio file existence
    const playerWrap = document.getElementById('audio-player-wrap');
    if (playerWrap && audio) {
      fetch(audio.src, { method: 'HEAD' }).then(r => {
        if (r.ok) playerWrap.style.display = '';
      }).catch(() => {});
    }

    // Toggle expand/collapse
    const toggleBtn = document.getElementById('audio-toggle-btn');
    const controlsEl = document.getElementById('audio-controls');
    let controlsVisible = false;
    if (toggleBtn && controlsEl) {
      toggleBtn.addEventListener('click', () => {
        controlsVisible = !controlsVisible;
        controlsEl.style.display = controlsVisible ? 'flex' : 'none';
      });
    }

    playBtn.addEventListener('click', () => {
      if (audio.paused) {
        const vttUrl = audio.src.replace('.mp3', '.vtt');
        if (!vttLoaded) loadVttAndBuild(vttUrl);
        audio.play();
        iconPlay.style.display = 'none';
        iconPause.style.display = '';
      } else {
        audio.pause();
        iconPlay.style.display = '';
        iconPause.style.display = 'none';
      }
    });

    audio.addEventListener('timeupdate', () => {
      if (!audio.duration) return;
      const pct = (audio.currentTime / audio.duration) * 100;
      if (progressFill) progressFill.style.width = pct + '%';
      if (timeEl) timeEl.textContent = `${formatTime(audio.currentTime)} / ${formatTime(audio.duration)}`;
      if (segments.length > 0) highlightAt(audio.currentTime);
    });

    audio.addEventListener('ended', () => {
      iconPlay.style.display = '';
      iconPause.style.display = 'none';
      if (progressFill) progressFill.style.width = '0%';
      clearHighlight();
    });

    audio.addEventListener('seeked', () => {
      if (segments.length > 0) highlightAt(audio.currentTime);
    });

    const progressBar = document.querySelector('.audio-progress-bar') as HTMLElement | null;
    progressBar?.addEventListener('click', (e: MouseEvent) => {
      const rect = progressBar.getBoundingClientRect();
      const ratio = (e.clientX - rect.left) / rect.width;
      if (audio.duration) audio.currentTime = ratio * audio.duration;
    });

    speedBtn?.addEventListener('click', () => {
      speedIdx = (speedIdx + 1) % speeds.length;
      const s = speeds[speedIdx];
      audio.playbackRate = s;
      speedBtn.textContent = s === 1 ? '1×' : `${s}×`;
    });
  }
</script>

  .page-block__body {
    font-size: 16px;
    line-height: 1.9;
  }

  /* Content typography */
  .content-paragraph {
    margin-bottom: 0.8em;
    color: #374151;
  }

  .content-heading {
    font-size: 17px;
    font-weight: 700;
    color: #1a1a1a;
    margin: 1.5em 0 0.5em;
    letter-spacing: -0.2px;
  }

  .content-subheading {
    font-size: 15px;
    font-weight: 600;
    color: #2d2d2d;
    margin: 1.2em 0 0.4em;
  }

  .content-list-item {
    margin-bottom: 0.4em;
    color: #374151;
    padding-left: 0.5em;
  }

  .content-blockquote {
    margin: 1em 0;
    padding: 0.6em 1em;
    border-left: 3px solid var(--color-border);
    color: var(--color-text-secondary);
    background: var(--color-surface);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    font-size: 15px;
  }

  .content-hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2em 0;
  }

  /* Inline color styles (no card wrapper) */
  .content-color--theorem {
    color: #c0392b;
    font-weight: 600;
  }

  .content-color--supplement {
    color: #2980b9;
    font-style: italic;
  }

  .content-color--corollary {

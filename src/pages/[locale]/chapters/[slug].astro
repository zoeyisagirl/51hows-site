  }

  @media (max-width: 1024px) {
    .chapter-layout {
      grid-template-columns: 1fr;
    }
    .chapter-toc {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .chapter-content {
      padding: 24px 20px 60px;
    }
    .chapter-header__body {
      flex-direction: column;
    }
    .chapter-nav {
      grid-template-columns: 1fr;
    }
    .color-legend__items {
      gap: 6px;
    }
  }

  /* Audio Player */
  .chapter-audio-player {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 16px;
    padding: 10px 16px;
    background: rgba(255,255,255,0.12);
    border-radius: 12px;
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.2);
    max-width: 480px;
  }
  .audio-play-btn {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(255,255,255,0.9);
    color: var(--ch-color, #333);
    border: none;
    cursor: pointer;
    font-size: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.15s, background 0.15s;
  }
  .audio-play-btn:hover {
    background: #fff;
    transform: scale(1.08);
  }
  .audio-info {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .audio-label {
    font-size: 12px;
    color: rgba(255,255,255,0.85);
    font-weight: 500;
    letter-spacing: 0.02em;
  }
  .audio-progress-wrap {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .audio-progress-bar {
    flex: 1;
    height: 4px;
    background: rgba(255,255,255,0.25);
    border-radius: 2px;
    cursor: pointer;
    overflow: hidden;
  }
  .audio-progress-fill {
    height: 100%;
    width: 0%;
    background: rgba(255,255,255,0.9);
    border-radius: 2px;
    transition: width 0.5s linear;
  }
  .audio-time {
    font-size: 11px;
    color: rgba(255,255,255,0.7);
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }
  .audio-speed-btn {
    flex-shrink: 0;
    padding: 4px 8px;
    border-radius: 6px;
    background: rgba(255,255,255,0.15);
    color: rgba(255,255,255,0.9);
    border: 1px solid rgba(255,255,255,0.2);
    font-size: 12px;
    cursor: pointer;
    transition: background 0.15s;
  }
  .audio-speed-btn:hover {
    background: rgba(255,255,255,0.25);
  }

  /* Audio reading highlight */
  .audio-reading {
    background: rgba(255, 230, 100, 0.35) !important;
    border-radius: 4px;
    transition: background 0.4s ease;
    outline: 2px solid rgba(255, 200, 50, 0.5);
    outline-offset: 2px;
  }
</style>

<script>
  const audio = document.getElementById('chapter-audio') as HTMLAudioElement | null;
  const playBtn = document.getElementById('audio-play-btn');
  const progressFill = document.getElementById('audio-progress-fill');
  const timeEl = document.getElementById('audio-time');
  const speedBtn = document.getElementById('audio-speed-btn');

  if (audio && playBtn) {
    const iconPlay = playBtn.querySelector('.audio-icon--play') as HTMLElement;
    const iconPause = playBtn.querySelector('.audio-icon--pause') as HTMLElement;
    const speeds = [1, 1.25, 1.5, 1.75, 2];
    let speedIdx = 0;

    function formatTime(s: number) {
      const m = Math.floor(s / 60);
      const sec = Math.floor(s % 60).toString().padStart(2, '0');
      return `${m}:${sec}`;
    }

    // ── Reading highlight (VTT-driven) ────────────────────────────────────
    type VttCue = { start: number; end: number; text: string };
    type SegInfo = { el: Element; start: number; end: number };
    let vttCues: VttCue[] = [];
    let segments: SegInfo[] = [];
    let lastHighlighted: Element | null = null;
    let vttLoaded = false;

    /** Parse WebVTT timestamp (HH:MM:SS.mmm) to seconds */
    function parseVttTs(ts: string): number {
      const parts = ts.trim().split(':');
      if (parts.length === 3) {
        return parseInt(parts[0]) * 3600 + parseInt(parts[1]) * 60 + parseFloat(parts[2]);
      }
      return parseInt(parts[0]) * 60 + parseFloat(parts[1]);
    }

    /** Parse a VTT file text into an array of cues */
    function parseVtt(text: string): VttCue[] {
      const cues: VttCue[] = [];
      const blocks = text.split(/\n\n+/);
      for (const block of blocks) {
        const lines = block.trim().split('\n');
        const tsLine = lines.find(l => l.includes('-->'));
        if (!tsLine) continue;
        const [startStr, endStr] = tsLine.split('-->').map(s => s.trim());
        const cueText = lines.slice(lines.indexOf(tsLine) + 1).join(' ').trim();
        if (cueText) {
          cues.push({ start: parseVttTs(startStr), end: parseVttTs(endStr), text: cueText });
        }
      }
      return cues;
    }

    /** Normalize text: remove whitespace + punctuation for fuzzy matching */
    function normalize(s: string): string {
      return s.replace(/[\s\u3000\u00a0，。！？、,.!?:：；;""''「」【】\-—]/g, '').toLowerCase();
    }

    /**
     * Build segments: assign each VTT cue to its DOM element,
     * then aggregate cues per element to get [start, end] ranges.
     *
     * Key insight: walk VTT cues in order (they match audio order),
     * and for each cue, find which DOM node contains its text.
     * A DOM node's time range = first matched cue's start → last matched cue's end.
     */
    function buildSegments() {
      const container = document.querySelector('.chapter-content');
      if (!container || vttCues.length === 0) return;

      const nodes = Array.from(
        container.querySelectorAll('h2, h3, h4, p')
      ).filter(el => (el.textContent || '').trim().length > 3);

      if (nodes.length === 0) return;

      // Pre-normalize all DOM node texts for matching
      const nodeNorms = nodes.map(el => normalize((el.textContent || '').trim()));

      // For each node, store matched cue indices
      const nodeCueMap = new Map<Element, number[]>();

      let nodeIdx = 0;

      for (let ci = 0; ci < vttCues.length; ci++) {
        const cueNorm = normalize(vttCues[ci].text);
        if (cueNorm.length < 2) continue;

        // Try to find which node this cue belongs to
        // Walk nodeIdx forward, but allow small look-back
        const searchStart = Math.max(0, nodeIdx - 1);

        let matchedNode = -1;
        for (let ni = searchStart; ni < nodes.length; ni++) {
          const nn = nodeNorms[ni];
          // Check: cue text is a substring of node text, OR node text starts with cue text
          if (nn.length >= cueNorm.length && nn.includes(cueNorm)) {
            matchedNode = ni;
            break;
          }
          // Also check: node text starts with cue text (cue might be beginning of paragraph)
          if (nn.length >= cueNorm.length && nn.startsWith(cueNorm)) {
            matchedNode = ni;
            break;
          }
          // Reverse: cue text starts with node text (short heading)
          if (cueNorm.length >= nn.length && cueNorm.startsWith(nn)) {
            matchedNode = ni;
            break;
          }
        }

        if (matchedNode >= 0) {
          nodeIdx = matchedNode; // advance
          const el = nodes[matchedNode];
          if (!nodeCueMap.has(el)) nodeCueMap.set(el, []);
          nodeCueMap.get(el)!.push(ci);
        }
      }

      // Build segments from matched cues
      segments = [];
      for (const el of nodes) {
        const cueIndices = nodeCueMap.get(el);
        if (!cueIndices || cueIndices.length === 0) continue;
        segments.push({
          el,
          start: vttCues[cueIndices[0]].start,
          end: vttCues[cueIndices[cueIndices.length - 1]].end,
        });
      }

      // Ensure segments don't overlap (end of one = start of next)
      for (let i = 0; i < segments.length - 1; i++) {
        if (segments[i].end > segments[i + 1].start) {
          segments[i].end = segments[i + 1].start;
        }
      }

      console.log(`[Audio] Built ${segments.length} segments from ${vttCues.length} VTT cues`);
    }

    function highlightAt(t: number) {
      // Binary search for current segment
      let lo = 0, hi = segments.length - 1, found = -1;
      while (lo <= hi) {
        const mid = (lo + hi) >> 1;
        if (segments[mid].end < t) { lo = mid + 1; }
        else if (segments[mid].start > t) { hi = mid - 1; }
        else { found = mid; break; }
      }
      const target = found >= 0 ? segments[found].el : null;
      if (target === lastHighlighted) return;
      if (lastHighlighted) lastHighlighted.classList.remove('audio-reading');
      if (target) {
        target.classList.add('audio-reading');
        const rect = target.getBoundingClientRect();
        if (rect.top < 80 || rect.bottom > window.innerHeight - 40) {
          target.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
      }
      lastHighlighted = target;
    }

    function clearHighlight() {
      if (lastHighlighted) lastHighlighted.classList.remove('audio-reading');
      lastHighlighted = null;
    }

    /** Load VTT file and build segments (called once on first play) */
    async function loadVttAndBuild(vttUrl: string) {
      if (vttLoaded) return;
      vttLoaded = true;
      try {
        const res = await fetch(vttUrl);
        if (!res.ok) return;
        const text = await res.text();
        vttCues = parseVtt(text);
        buildSegments();
      } catch (e) {
        console.warn('VTT load failed, highlight disabled', e);
      }
    }
    // ─────────────────────────────────────────────────────────────────────

    playBtn.addEventListener('click', () => {
      if (audio.paused) {
        // Load VTT on first play
        const vttUrl = (audio as HTMLAudioElement).src.replace('.mp3', '.vtt');
        if (!vttLoaded) loadVttAndBuild(vttUrl);
        audio.play();
        iconPlay.style.display = 'none';
        iconPause.style.display = '';
      } else {
        audio.pause();
        iconPlay.style.display = '';
        iconPause.style.display = 'none';
      }
    });

    audio.addEventListener('timeupdate', () => {
      if (!audio.duration) return;
      const pct = (audio.currentTime / audio.duration) * 100;
      if (progressFill) progressFill.style.width = pct + '%';
      if (timeEl) timeEl.textContent = `${formatTime(audio.currentTime)} / ${formatTime(audio.duration)}`;
      // Update highlight
      if (segments.length > 0) highlightAt(audio.currentTime);
    });

    audio.addEventListener('ended', () => {
      iconPlay.style.display = '';
      iconPause.style.display = 'none';
      if (progressFill) progressFill.style.width = '0%';
      clearHighlight();
    });

    audio.addEventListener('pause', () => {
      // Keep highlight visible on pause (don't clear)
    });

    // Rebuild segments on seek (in case user jumps)
    audio.addEventListener('seeked', () => {
      if (segments.length > 0) highlightAt(audio.currentTime);
    });

    // Click on progress bar to seek
    const progressBar = document.querySelector('.audio-progress-bar') as HTMLElement | null;
    progressBar?.addEventListener('click', (e: MouseEvent) => {
      const rect = progressBar.getBoundingClientRect();
      const ratio = (e.clientX - rect.left) / rect.width;
      if (audio.duration) audio.currentTime = ratio * audio.duration;
    });

    // Speed control
    speedBtn?.addEventListener('click', () => {
      speedIdx = (speedIdx + 1) % speeds.length;
      const s = speeds[speedIdx];
      audio.playbackRate = s;
      speedBtn.textContent = s === 1 ? '1×' : `${s}×`;
    });
  }
</script>

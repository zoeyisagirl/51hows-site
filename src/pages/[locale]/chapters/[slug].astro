---
import Layout from '../../../layouts/Layout.astro';
import { chapters, concepts } from '../../../data/chapters';
import { getDictionary, type Locale } from '../../../i18n';
import type { GetStaticPaths } from 'astro';
import { readFileSync, existsSync } from 'node:fs';
import { join } from 'node:path';

// Tag translation mapping for tags that are not standalone concepts
const tagEnMap: Record<string, string> = {
  '厉害/不厉害': 'Elite / Non-Elite',
  '发育线': 'Development Track',
  '人生哲学': 'Core Philosophy',
  // Chapter 1
  '理财': 'Wealth Management',
  '投资': 'Investing',
  'W₀': 'W₀',
  '价值投资': 'Value Investing',
  '财富自由': 'Financial Freedom',
  // Chapter 2
  '上岸': 'Reaching the Shore',
  'W₁': 'W₁',
  'W₂': 'W₂',
  // Chapter 3
  '保级': 'Maintaining Position',
  '财富保全': 'Wealth Preservation',
  '认知框架': 'Cognitive Framework',
  '生活方式': 'Lifestyle',
  // Chapter 4
  '创业': 'Entrepreneurship',
  '搞事': 'Making Things Happen',
  '梦幻队长': 'Dream Team Captain',
  '0到1': '0 to 1',
  '原创贡献': 'Original Contribution',
  // Chapter 5
  '预测未来': 'Predicting the Future',
  '技术趋势': 'Technological Trends',
  '历史规律': 'Historical Patterns',
  '凸包': 'Convex Hull',
  // Chapter 6
  '番外': 'Extra',
  '二流技术': 'Second-Tier Techniques',
  '实用指南': 'Practical Guide',
  // Common
  '端盘儿菜': 'Serve Original Dishes',
  'The Passion': 'The Passion',
};

export function getStaticPaths() {
  const paths: { params: { locale: string; slug: string }; props: { chapter: (typeof chapters)[0]; locale: Locale } }[] = [];
  for (const ch of chapters.filter(c => c.status === 'available')) {
    paths.push({ params: { locale: 'zh', slug: ch.slug }, props: { chapter: ch, locale: 'zh' as Locale } });
    paths.push({ params: { locale: 'en', slug: ch.slug }, props: { chapter: ch, locale: 'en' as Locale } });
  }
  return paths;
}

const { chapter, locale } = Astro.props;
const t = getDictionary(locale);

// Read from content/chapters directory — prefer localized version
const contentDir = join(process.cwd(), 'src/content/chapters');
const enFilePath = join(contentDir, `${chapter.id}-en.md`);
const zhFilePath = join(contentDir, `${chapter.id}.md`);
const filePath = (locale === 'en') && existsSync(enFilePath) ? enFilePath : zhFilePath;
let rawContent = '';
try {
  rawContent = readFileSync(filePath, 'utf-8');
} catch (e) {
  // Fallback: try the other locale's file
  const fallbackPath = filePath === enFilePath ? zhFilePath : enFilePath;
  try { rawContent = readFileSync(fallbackPath, 'utf-8'); } catch (_) { rawContent = ''; }
}

// Parse markdown content with semantic blocks
interface ContentBlock {
  type: 'text' | 'blockquote' | 'theorem' | 'supplement' | 'corollary' | 'fact' | 'guess' | 'innovation';
  content: string;
  children?: ContentBlock[];
}

function parseColorBlocks(text: string, insideBlockquote = false): ContentBlock[] {
  const blocks: ContentBlock[] = [];
  const blockPattern = /^(?:>)?:::(theorem|supplement|corollary|fact|guess|innovation)\s*\n([\s\S]*?)(?:>)?:::/gm;

  const matches: Array<{type: string, content: string, start: number, end: number}> = [];
  let match;
  while ((match = blockPattern.exec(text)) !== null) {
    matches.push({
      type: match[1],
      content: match[2].trim(),
      start: match.index,
      end: match.index + match[0].length
    });
  }

  if (matches.length === 0) {
    const cleaned = insideBlockquote ? text.replace(/^>\s?/gm, '').trim() : text.trim();
    if (cleaned) blocks.push({ type: 'text', content: cleaned });
    return blocks;
  }

  let lastIndex = 0;
  for (const m of matches) {
    if (m.start > lastIndex) {
      const before = text.slice(lastIndex, m.start).trim();
      const cleaned = insideBlockquote ? before.replace(/^>\s?/gm, '').trim() : before;
      if (cleaned) blocks.push({ type: 'text', content: cleaned });
    }
    const cleanContent = m.content.replace(/^>\s?/gm, '').trim();
    blocks.push({ type: m.type as ContentBlock['type'], content: cleanContent });
    lastIndex = m.end;
  }

  if (lastIndex < text.length) {
    const after = text.slice(lastIndex).trim();
    const cleaned = insideBlockquote ? after.replace(/^>\s?/gm, '').trim() : after;
    if (cleaned) blocks.push({ type: 'text', content: cleaned });
  }

  return blocks;
}

function parseContent(text: string): ContentBlock[] {
  const blocks: ContentBlock[] = [];
  const lines = text.split('\n');
  let i = 0;

  while (i < lines.length) {
    const line = lines[i];

    if (line.match(/^\>\s?/)) {
      const bqLines: string[] = [];
      while (i < lines.length && (lines[i].match(/^\>\s?/) || lines[i].match(/^:::/) || lines[i] === ':::' || lines[i] === '::')) {
        bqLines.push(lines[i]);
        i++;
      }
      const bqText = bqLines.join('\n');
      const children = parseColorBlocks(bqText, true);
      blocks.push({ type: 'blockquote', content: bqText, children });
    } else if (line.match(/^:::/) || line === ':::' || line === '::') {
      i++;
    } else {
      const textLines: string[] = [];
      while (i < lines.length && !lines[i].match(/^\>\s?/) && !lines[i].match(/^:::/)) {
        textLines.push(lines[i]);
        i++;
      }
      const textChunk = textLines.join('\n').trim();
      if (textChunk && !textChunk.startsWith('<!--') && textChunk !== '---') {
        const colorBlocks = parseColorBlocks(textChunk, false);
        blocks.push(...colorBlocks);
      } else if (textChunk === '---') {
        blocks.push({ type: 'text', content: '---' });
      }
    }
  }

  return blocks;
}

interface Page {
  num: string;
  content: string;
  blocks: ContentBlock[];
}

const pages: Page[] = [];
if (rawContent) {
  const withoutFrontmatter = rawContent.replace(/^---[\s\S]*?---\n/, '');
  const pageSections = withoutFrontmatter.split(/<!-- Page (\d+) -->/).filter(s => s.trim());

  if (pageSections.length > 1 && /<!-- Page \d+ -->/.test(withoutFrontmatter)) {
    for (let i = 0; i < pageSections.length; i += 2) {
      const pageNum = pageSections[i] || `${Math.floor(i/2) + 1}`;
      const pageContent = pageSections[i + 1] || '';
      if (pageContent.trim()) {
        const blocks = parseContent(pageContent);
        pages.push({
          num: pageNum.padStart(2, '0'),
          content: pageContent.trim(),
          blocks
        });
      }
    }
  } else {
    const blocks = parseContent(withoutFrontmatter);
    if (blocks.length > 0) {
      pages.push({ num: '01', content: withoutFrontmatter.trim(), blocks });
    }
  }
}

const available = chapters.filter(c => c.status === 'available');
const idx = available.findIndex(c => c.id === chapter.id);
const prev = idx > 0 ? available[idx - 1] : null;
const next = idx < available.length - 1 ? available[idx + 1] : null;

// Use localized type labels
const typeLabels = t.typeLabels;

function renderInline(text: string): string {
  const cleaned = text.replace(/^>\s?/gm, '');
  return cleaned
    .replace(/==(.+?)==/g, '<mark class="highlight-mark">$1</mark>')
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.+?)\*/g, '<em>$1</em>')
    .replace(/^### (.+)$/gm, '<h3>$1</h3>')
    .replace(/^## (.+)$/gm, '<h2>$1</h2>')
    .replace(/^# (.+)$/gm, '<h1>$1</h1>')
    .replace(/^---$/gm, '<hr/>')
    .replace(/^\*(.+)\*$/gm, '<p><em>$1</em></p>');
}
---

<Layout title={locale === 'en' && chapter.titleEn ? chapter.titleEn : chapter.title} locale={locale} t={t}>
  <div class="chapter-page">
    <!-- Chapter header -->
    <div class="chapter-header" style={`--ch-color: ${chapter.color};`}>
      <div class="container">
        <div class="chapter-header__breadcrumb">
          <a href={`/${locale}`}>{t.chapterDetail.breadcrumbHome}</a>
          <span>/</span>
          <a href={`/${locale}/chapters`}>{t.chapterDetail.breadcrumbChapters}</a>
          <span>/</span>
          <span>{locale === 'en' && chapter.titleEn ? chapter.titleEn : chapter.title}</span>
        </div>
        <div class="chapter-header__body">
          <div class="chapter-header__num">{chapter.number ?? '·'}</div>
          <div class="chapter-header__info">
            <h1 class="chapter-header__title">{locale === 'en' && chapter.titleEn ? chapter.titleEn : chapter.title}</h1>
            <p class="chapter-header__subtitle">{chapter.subtitle}</p>
            <p class="chapter-header__desc">{locale === 'en' && chapter.descriptionEn ? chapter.descriptionEn : chapter.description}</p>
            <div class="chapter-header__meta">
              <span class="meta-badge">{chapter.publishDate}</span>
              <span class="meta-badge">{t.chapterDetail.pagesLabel.replace('{count}', String(pages.length))}</span>
              <span class="meta-badge">{chapter.type === 'extra' ? t.chapterDetail.extraChapter : chapter.type === 'intro' ? t.chapterDetail.introChapter : t.chapterDetail.mainSeries}</span>
            </div>
          </div>
        </div>
        <div class="chapter-header__tags">
          {chapter.tags.map(tg => {
            const concept = concepts.find(c => c.id === tg || c.title === tg);
            const label = locale === 'en'
              ? (concept?.titleEn || tagEnMap[tg] || tg)
              : tg;
            return <span class="tag">{label}</span>;
          })}
        </div>
      </div>
    </div>

    <!-- Color legend -->
    <div class="color-legend">
      <div class="container">
        <div class="color-legend__inner">
          <span class="color-legend__label">{t.chapterDetail.colorLegend}</span>
          <div class="color-legend__items">
            <span class="legend-item legend-item--theorem">{t.chapterDetail.legendTheorem}</span>
            <span class="legend-item legend-item--supplement">{t.chapterDetail.legendSupplement}</span>
            <span class="legend-item legend-item--corollary">{t.chapterDetail.legendCorollary}</span>
            <span class="legend-item legend-item--fact">{t.chapterDetail.legendFact}</span>
            <span class="legend-item legend-item--guess">{t.chapterDetail.legendGuess}</span>
            <span class="legend-item legend-item--innovation">{t.chapterDetail.legendInnovation}</span>
          </div>
        </div>
      </div>
    </div>

    <div class="chapter-layout">
      <!-- TOC sidebar -->
      <aside class="chapter-toc">
        <div class="toc-inner">
          <div class="toc-title">{t.chapterDetail.tocTitle}</div>
          <ul class="toc-list">
            {pages.map((p, i) => (
              <li>
                <a href={`#page-${p.num}`} class="toc-item">
                  {t.chapterDetail.tocPage.replace('{num}', p.num)}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </aside>

      <!-- Content -->
      <main class="chapter-content">
        {pages.length > 0 ? (
          pages.map((page) => (
            <div id={`page-${page.num}`} class="page-block">
              <div class="page-block__header">
                <span class="page-num">{t.chapterDetail.pageHeader.replace('{num}', page.num)}</span>
              </div>
              <div class="page-block__body">
                {page.blocks.map(block => {
                    if (block.type === 'text') {
                    const lines = block.content.split('\n');
                    return lines.map(line => {
                      const trimmed = line.trim();
                      if (!trimmed) return null;
                      if (/^#{1,4}\s/.test(trimmed)) {
                        const level = trimmed.match(/^(#{1,4})\s/)[1].length;
                        const headingText = trimmed.replace(/^#{1,4}\s/, '');
                        const Tag = `h${level}` as 'h1' | 'h2' | 'h3' | 'h4';
                        return <Tag class={level <= 2 ? 'content-heading' : 'content-subheading'} set:html={renderInline(headingText)} />;
                      }
                      if (trimmed === '---') {
                        return <hr class="content-hr" />;
                      }
                      if (/^\d+\.\d+[a-z]?\.\d+/.test(trimmed)) {
                        return <h4 class="content-subheading" set:html={renderInline(trimmed)} />;
                      }
                      if (/^\d+\.[a-z]?/.test(trimmed) && !/^\d+\.\d+[a-z]?\.\d/.test(trimmed)) {
                        return <h3 class="content-heading" set:html={renderInline(trimmed)} />;
                      }
                      if (/^[QA]:\s/i.test(trimmed)) {
                        return <p class="content-paragraph" style="font-weight:600;" set:html={renderInline(trimmed)} />;
                      }
                      return <p class="content-paragraph" set:html={renderInline(trimmed)} />;
                    });
                  } else if (block.type === 'blockquote') {
                    const children = block.children || [];
                    return (
                      <>
                        {children.map(child => {
                          if (child.type === 'text') {
                            const lines = child.content.split('\n').filter(l => l.trim());
                            const headings: string[] = [];
                            const normalLines: string[] = [];
                            for (const line of lines) {
                              const trimmed = line.trim();
                              if (/^#{1,3}\s/.test(trimmed)) {
                                headings.push(trimmed);
                              } else {
                                normalLines.push(trimmed);
                              }
                            }
                            return (
                              <>
                                {headings.map(h => <Fragment set:html={renderInline(h)} />)}
                                {normalLines.length > 0 && (
                                  <blockquote class="content-blockquote">
                                    {normalLines.map(line => (
                                      <p set:html={renderInline(line)} />
                                    ))}
                                  </blockquote>
                                )}
                              </>
                            );
                          } else {
                            const paras = child.content.split('\n').filter(l => l.trim());
                            return (
                              <blockquote class="content-blockquote">
                                {paras.map(line => (
                                  <p class={`content-color--${child.type}`} set:html={renderInline(line.trim())} />
                                ))}
                              </blockquote>
                            );
                          }
                        })}
                      </>
                    );
                  } else {
                    const paras = block.content.split('\n').filter(l => l.trim());
                    return paras.map(line => {
                      const trimmed = line.trim();
                      if (!trimmed) return null;
                      return <p class={`content-paragraph content-color--${block.type}`} set:html={renderInline(trimmed)} />;
                    });
                  }
                })}
              </div>
            </div>
          ))
        ) : (
          <div class="empty-state">
            <p>{t.chapterDetail.emptyState}</p>
          </div>
        )}

        <!-- Nav -->
        <nav class="chapter-nav">
          {prev ? (
            <a href={`/${locale}/chapters/${prev.slug}`} class="chapter-nav__item chapter-nav__item--prev">
              <span class="chapter-nav__label">{t.chapterDetail.prevChapter}</span>
              <span class="chapter-nav__title">{locale === 'en' && prev.titleEn ? prev.titleEn : prev.title}</span>
            </a>
          ) : <div />}
          {next ? (
            <a href={`/${locale}/chapters/${next.slug}`} class="chapter-nav__item chapter-nav__item--next">
              <span class="chapter-nav__label">{t.chapterDetail.nextChapter}</span>
              <span class="chapter-nav__title">{locale === 'en' && next.titleEn ? next.titleEn : next.title}</span>
            </a>
          ) : <div />}
        </nav>
      </main>
    </div>
  </div>
</Layout>

<style>
  .chapter-header {
    padding: 48px 0;
    border-bottom: 1px solid var(--color-border);
    background: linear-gradient(to bottom, rgba(255,255,255,0) 0%, var(--color-border-subtle) 100%);
    position: relative;
  }

  .chapter-header::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 4px;
    background: var(--ch-color);
  }

  .chapter-header__breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--color-text-muted);
    margin-bottom: 32px;
  }

  .chapter-header__breadcrumb a {
    color: var(--color-text-secondary);
    text-decoration: none;
  }

  .chapter-header__breadcrumb a:hover {
    text-decoration: underline;
  }

  .chapter-header__body {
    display: flex;
    align-items: flex-start;
    gap: 24px;
    margin-bottom: 20px;
  }

  .chapter-header__num {
    flex-shrink: 0;
    width: 64px;
    height: 64px;
    border-radius: 14px;
    background: var(--ch-color);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28px;
    font-weight: 700;
    letter-spacing: -2px;
  }

  .chapter-header__title {
    font-size: 32px;
    font-weight: 700;
    letter-spacing: -0.8px;
    margin-bottom: 6px;
  }

  .chapter-header__subtitle {
    font-size: 14px;
    color: var(--color-text-muted);
    font-style: italic;
    margin-bottom: 12px;
  }

  .chapter-header__desc {
    font-size: 16px;
    color: var(--color-text-secondary);
    line-height: 1.7;
    max-width: 640px;
    margin-bottom: 16px;
  }

  .chapter-header__meta {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .meta-badge {
    display: inline-block;
    padding: 3px 10px;
    border-radius: 100px;
    font-size: 12px;
    font-weight: 500;
    background: var(--color-surface);
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
  }

  .chapter-header__tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-top: 4px;
  }

  .tag {
    padding: 3px 10px;
    border-radius: 100px;
    font-size: 12px;
    color: var(--color-text-muted);
    background: rgba(0,0,0,0.04);
    border: 1px solid var(--color-border);
  }

  /* Color legend */
  .color-legend {
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    padding: 12px 0;
  }

  .color-legend__inner {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .color-legend__label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  .color-legend__items {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .legend-item {
    font-size: 12px;
    padding: 2px 10px;
    border-radius: 100px;
    font-weight: 500;
  }

  .legend-item--theorem {
    background: rgba(231, 76, 60, 0.1);
    color: #c0392b;
    border: 1px solid rgba(231, 76, 60, 0.2);
  }

  .legend-item--supplement {
    background: rgba(52, 152, 219, 0.1);
    color: #2980b9;
    border: 1px solid rgba(52, 152, 219, 0.2);
  }

  .legend-item--corollary {
    background: rgba(230, 126, 34, 0.1);
    color: #d35400;
    border: 1px solid rgba(230, 126, 34, 0.2);
  }

  .legend-item--fact {
    background: rgba(39, 174, 96, 0.1);
    color: #1e8449;
    border: 1px solid rgba(39, 174, 96, 0.2);
  }

  .legend-item--guess {
    background: rgba(155, 89, 182, 0.1);
    color: #7d3c98;
    border: 1px solid rgba(155, 89, 182, 0.2);
  }

  .legend-item--innovation {
    background: rgba(149, 165, 166, 0.2);
    color: #5d6d7e;
    border: 1px solid rgba(149, 165, 166, 0.3);
    font-weight: 600;
  }

  /* Layout */
  .chapter-layout {
    display: grid;
    grid-template-columns: 220px 1fr;
    max-width: 1200px;
    margin: 0 auto;
    gap: 0;
    min-height: 100vh;
  }

  /* TOC */
  .chapter-toc {
    border-right: 1px solid var(--color-border);
    position: sticky;
    top: var(--nav-height);
    height: calc(100vh - var(--nav-height));
    overflow-y: auto;
  }

  .toc-inner {
    padding: 28px 16px;
  }

  .toc-title {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 12px;
    padding: 0 8px;
  }

  .toc-list {
    list-style: none;
    margin-bottom: 24px;
  }

  .toc-item {
    display: block;
    padding: 5px 8px;
    border-radius: var(--radius-sm);
    font-size: 13px;
    color: var(--color-text-secondary);
    transition: all 0.15s;
    text-decoration: none;
  }

  .toc-item:hover {
    color: var(--color-text);
    background: var(--color-border-subtle);
  }

  /* Content */
  .chapter-content {
    padding: 40px 56px 80px;
    max-width: 800px;
  }

  .page-block {
    margin-bottom: 48px;
    padding-bottom: 48px;
    border-bottom: 1px solid var(--color-border-subtle);
    scroll-margin-top: calc(var(--nav-height) + 20px);
  }

  .page-block:last-of-type {
    border-bottom: none;
  }

  .page-block__header {
    margin-bottom: 16px;
  }

  .page-num {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    padding: 2px 8px;
    border-radius: 100px;
    background: var(--color-border-subtle);
    border: 1px solid var(--color-border);
  }

  .page-block__body {
    font-size: 16px;
    line-height: 1.9;
  }

  /* Content typography */
  .content-paragraph {
    margin-bottom: 0.8em;
    color: #374151;
  }

  .content-heading {
    font-size: 17px;
    font-weight: 700;
    color: #1a1a1a;
    margin: 1.5em 0 0.5em;
    letter-spacing: -0.2px;
  }

  .content-subheading {
    font-size: 15px;
    font-weight: 600;
    color: #2d2d2d;
    margin: 1.2em 0 0.4em;
  }

  .content-list-item {
    margin-bottom: 0.4em;
    color: #374151;
    padding-left: 0.5em;
  }

  .content-blockquote {
    margin: 1em 0;
    padding: 0.6em 1em;
    border-left: 3px solid var(--color-border);
    color: var(--color-text-secondary);
    background: var(--color-surface);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    font-size: 15px;
  }

  .content-hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2em 0;
  }

  /* Inline color styles (no card wrapper) */
  .content-color--theorem {
    color: #c0392b;
    font-weight: 600;
  }

  .content-color--supplement {
    color: #2980b9;
    font-style: italic;
  }

  .content-color--corollary {
    color: #d35400;
    font-weight: 600;
  }

  .content-color--fact {
    color: #1e8449;
  }

  .content-color--guess {
    color: #7d3c98;

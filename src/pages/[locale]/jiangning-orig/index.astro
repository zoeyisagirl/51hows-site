---
import Layout from '../../../layouts/Layout.astro';
import { getDictionary, type Locale } from '../../../i18n';

export function getStaticPaths() {
  return [{ params: { locale: 'zh' } }, { params: { locale: 'en' } }];
}

const { locale } = Astro.params as { locale: Locale };
const t = getDictionary('zh');
---

<Layout title={t.jiangningOrigPage.heading} locale={locale} t={t} disableLangSwitch={true}>
  <div class="container" style="padding-top:48px; padding-bottom:80px;">
    <div class="page-header">
      <p class="section-title">{t.jiangningOrigPage.sectionTitle}</p>
      <h1 class="section-heading">{t.jiangningOrigPage.heading}</h1>
      <p class="page-desc">{t.jiangningOrigPage.description}</p>
    </div>

    <div class="coming-soon">
      <div class="coming-soon__icon">📖</div>
      <p class="coming-soon__text">{t.jiangningOrigPage.comingSoon}</p>
    </div>
  </div>
</Layout>

<style>
  .page-header {
    margin-bottom: 48px;
  }

  .page-desc {
    color: var(--color-text-secondary);
    font-size: 16px;
    margin-top: 12px;
    max-width: 600px;
    line-height: 1.7;
  }

  .coming-soon {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 80px 24px;
    text-align: center;
  }

  .coming-soon__icon {
    font-size: 48px;
    margin-bottom: 16px;
  }

  .coming-soon__text {
    font-size: 16px;
    color: var(--color-text-muted);
    font-weight: 500;
  }
</style>

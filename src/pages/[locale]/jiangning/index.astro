---
import Layout from '../../../layouts/Layout.astro';
import { jiangningPosts } from '../../../data/jiangning-posts';
import { getDictionary, type Locale } from '../../../i18n';

export function getStaticPaths() {
  return [{ params: { locale: 'zh' } }, { params: { locale: 'en' } }];
}

const { locale } = Astro.params as { locale: Locale };
const t = getDictionary('zh');
---

<Layout title={t.jiangningPage.heading} locale={locale} t={t} disableLangSwitch={true}>
  <div class="container" style="padding-top:48px; padding-bottom:80px;">
    <div class="page-header">
      <p class="section-title">{t.jiangningPage.sectionTitle}</p>
      <h1 class="section-heading">{t.jiangningPage.heading}</h1>
      <p class="page-desc">{t.jiangningPage.description}</p>
      <div class="author-card">
        <span class="author-card__label">{t.jiangningPage.authorLabel}</span>
        <span class="author-card__name">{t.jiangningPage.authorName}</span>
        <span class="author-card__sep">·</span>
        <span class="author-card__source">{t.jiangningPage.authorSource}</span>
      </div>
    </div>

    <div class="posts-list">
      {jiangningPosts.map(post => (
        <a href={`/${locale}/jiangning/${post.slug}`} class="post-card" style={`--art-color: ${post.color};`}>
          <div class="post-card__num">{post.number}</div>
          <div class="post-card__body">
            <h3 class="post-card__title">{post.title}</h3>
            <p class="post-card__desc">{post.description}</p>
            <div class="post-card__meta">
              <span class="meta-badge">{post.publishDate}</span>
              <span class="meta-badge meta-badge--author">{post.author}</span>
              <span class="meta-badge meta-badge--source">{post.source}</span>
              {post.tags.slice(0, 3).map(tag => (
                <span class="meta-badge meta-badge--tag">{tag}</span>
              ))}
            </div>
          </div>
          <div class="post-card__arrow">→</div>
        </a>
      ))}
    </div>
  </div>
</Layout>

<style>
  .page-header {
    margin-bottom: 48px;
  }

  .page-desc {
    color: var(--color-text-secondary);
    font-size: 16px;
    margin-top: 12px;
    max-width: 600px;
    line-height: 1.7;
  }

  .author-card {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 20px;
    padding: 8px 16px;
    background: var(--color-border-subtle);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-size: 14px;
  }

  .author-card__label {
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .author-card__name {
    color: var(--color-text);
    font-weight: 600;
  }

  .author-card__sep {
    color: var(--color-border);
  }

  .author-card__source {
    color: var(--color-text-secondary);
  }

  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 800px;
  }

  .post-card {
    display: flex;
    align-items: flex-start;
    gap: 20px;
    padding: 24px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: inherit;
    transition: all 0.2s;
    position: relative;
    overflow: hidden;
  }

  .post-card::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 4px;
    background: var(--art-color);
    opacity: 0;
    transition: opacity 0.2s;
  }

  .post-card:hover {
    transform: translateX(4px);
    box-shadow: var(--shadow-md);
    border-color: var(--art-color);
  }

  .post-card:hover::before { opacity: 1; }

  .post-card__num {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: var(--art-color);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -1px;
  }

  .post-card__body { flex: 1; min-width: 0; }

  .post-card__title {
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -0.3px;
    margin-bottom: 6px;
    line-height: 1.4;
  }

  .post-card__desc {
    font-size: 14px;
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: 12px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-card__meta {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .meta-badge {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 100px;
    font-size: 12px;
    font-weight: 500;
    background: var(--color-border-subtle);
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
  }

  .meta-badge--tag {
    background: transparent;
    color: var(--color-text-muted);
    border-color: var(--color-border);
  }

  .meta-badge--author {
    color: var(--color-text);
    border-color: var(--color-border);
    background: var(--color-surface);
    font-weight: 600;
  }

  .meta-badge--source {
    color: var(--art-color);
    border-color: var(--art-color);
    background: transparent;
  }

  .post-card__arrow {
    flex-shrink: 0;
    font-size: 20px;
    color: var(--color-text-muted);
    align-self: center;
    transition: transform 0.2s;
  }

  .post-card:hover .post-card__arrow {
    transform: translateX(4px);
  }

  @media (max-width: 768px) {
    .post-card {
      flex-direction: column;
      gap: 12px;
    }
    .post-card__arrow {
      display: none;
    }
  }
</style>
